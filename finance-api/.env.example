# Required — get keys from each provider's free tier
FINNHUB_API_KEY=your_finnhub_api_key_here
FMP_API_KEY=your_fmp_api_key_here

# Optional — CoinGecko free tier works without a key but rate limits are tighter
COINGECKO_API_KEY=

# Tuning
QUOTE_TIMEOUT_SECONDS=5.0
HTTP_VERIFY_TLS=true
# Optional custom CA bundle path (overrides HTTP_VERIFY_TLS when set)
HTTP_CA_BUNDLE=
LOG_LEVEL=INFO
DEBUG=false
# Comma-separated list. Example:
# CORS_ALLOW_ORIGINS=https://dovizveri.com,https://www.dovizveri.com,https://doviz-ui.onrender.com
CORS_ALLOW_ORIGINS=*
